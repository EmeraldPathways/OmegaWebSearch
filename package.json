{
  "name": "google-search-scraper-actor",
  "version": "0.1.0",
  "description": "Apify actor for scraping Google Search Engine Results Pages (SERPs) — HTTP-based, no browser required",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc",
    "build:server": "tsc -p tsconfig.server.json",
    "start": "node dist/main.js",
    "start:server": "node dist/server/index.js",
    "dev": "ts-node src/main.ts",
    "dev:server": "ts-node -P tsconfig.server.json server/index.ts"
  },
  "dependencies": {
    "apify": "^3.2.2",
    "cheerio": "^1.0.0",
    "dotenv": "^17.3.1",
    "express": "^4.19.2",
    "undici": "^6.6.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  }
}
